{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResumeProfile",
  "description": "简历结构化数据Schema，所有Agent共享的标准格式",
  "type": "object",
  "required": ["basics", "education", "work_experience", "skills", "metadata"],
  "properties": {
    "basics": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "姓名" },
        "phone": { "type": ["string", "null"], "description": "电话号码" },
        "email": { "type": ["string", "null"], "format": "email", "description": "邮箱" },
        "degree": { "type": ["string", "null"], "description": "最高学历" },
        "graduation_year": { "type": ["integer", "null"], "description": "毕业年份" },
        "target_role": { "type": ["string", "null"], "description": "目标岗位" },
        "summary": { "type": ["string", "null"], "description": "个人摘要" }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["school", "major"],
        "properties": {
          "school": { "type": "string" },
          "degree_type": { "type": "string", "enum": ["博士", "硕士", "本科", "专科", "其他"] },
          "major": { "type": "string" },
          "start_date": { "type": "string", "pattern": "^\\d{4}\\.\\d{2}$" },
          "end_date": { "type": "string" },
          "courses": { "type": "array", "items": { "type": "string" } },
          "awards": { "type": "array", "items": { "type": "string" } },
          "gpa": { "type": ["string", "null"] }
        }
      }
    },
    "work_experience": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["company", "role"],
        "properties": {
          "company": { "type": "string" },
          "role": { "type": "string" },
          "start_date": { "type": "string" },
          "end_date": { "type": "string" },
          "is_internship": { "type": "boolean", "default": false },
          "responsibilities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "category": { "type": "string", "description": "职责类别，如产品运营、营销推广" },
                "description": { "type": "string", "description": "职责描述原文" },
                "metrics": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "量化指标"
                },
                "keywords": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "关键技能/工具词"
                }
              }
            }
          }
        }
      }
    },
    "research": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "type": { "type": "string", "description": "项目类型，如国家基金项目" },
          "start_date": { "type": "string" },
          "end_date": { "type": "string" },
          "description": { "type": "string" },
          "contributions": { "type": "string" },
          "publications": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "venue": { "type": "string" },
                "status": { "type": "string", "enum": ["已发表", "在审", "在编"] }
              }
            }
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "properties": {
        "data_analysis": { "type": "array", "items": { "type": "string" } },
        "visualization": { "type": "array", "items": { "type": "string" } },
        "programming": { "type": "array", "items": { "type": "string" } },
        "ai_tools": { "type": "array", "items": { "type": "string" } },
        "design": { "type": "array", "items": { "type": "string" } },
        "media": { "type": "array", "items": { "type": "string" } },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "language": { "type": "string" },
              "level": { "type": "string" }
            }
          }
        },
        "other": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "extraction_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source_format": { "type": "string", "enum": ["pdf", "docx", "txt", "md"] },
        "missing_fields": { "type": "array", "items": { "type": "string" } },
        "open_questions": { "type": "array", "items": { "type": "string" } },
        "extracted_at": { "type": "string", "format": "date-time" },
        "version": { "type": "integer", "default": 1 }
      }
    }
  }
}
